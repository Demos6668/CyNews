{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "migrate:indexes": "node ./run-migration.cjs ./migrations/001_add_feed_indexes.sql",
    "migrate:india": "node ./run-migration.cjs ./migrations/002_add_india_fields.sql",
    "migrate:advisory-scope": "node ./run-migration.cjs ./migrations/003_add_advisory_scope.sql",
    "migrate:cert-in": "node ./run-migration.cjs ./migrations/004_add_cert_in_advisory_fields.sql",
    "migrate:retention": "node ./run-migration.cjs ./migrations/011_add_retention_tables.sql"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
