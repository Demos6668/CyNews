{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"if(!/pnpm/.test(process.env.npm_config_user_agent||''))throw new Error('Use pnpm instead')\"",
    "dev": "pnpm run --parallel --filter @workspace/api-server --filter @workspace/cyfy-news dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:frontend": "pnpm --filter @workspace/cyfy-news run dev",
    "db:up": "docker compose up -d db",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:push:force": "pnpm --filter @workspace/db exec drizzle-kit push --force",
    "setup": "pnpm install && pnpm run db:up && pnpm run db:push:force",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --filter \"./artifacts/**\" --if-present run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "pnpm --filter @workspace/e2e run test",
    "test:e2e:ui": "pnpm --filter @workspace/e2e run test:ui",
    "test:e2e:debug": "pnpm --filter @workspace/e2e run test:debug",
    "test:e2e:codegen": "pnpm --filter @workspace/e2e run test:codegen",
    "test:e2e:install": "pnpm --filter @workspace/e2e run install:browsers"
  },
  "private": true,
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.2"
  }
}
