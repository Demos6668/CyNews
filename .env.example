# Database connection (used by api-server directly in dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cynews
PORT=8080

# Docker Compose PostgreSQL settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=cynews

# CORS - comma-separated origins (leave empty to allow all in dev)
# CORS_ORIGINS=https://yourdomain.example.com

# Optional: threat intel API keys (free at https://auth.abuse.ch/)
# URLHAUS_AUTH_KEY=...
# THREATFOX_AUTH_KEY=...
