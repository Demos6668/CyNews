# === Local Development ===
# Copy this file: cp .env.example .env
# These defaults work out-of-the-box with `docker compose up -d db`

# Database (must match POSTGRES_* values below)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cynews
PORT=8080

# Docker Compose PostgreSQL settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cynews

# API Key — gates all POST/PUT/DELETE endpoints.
# WARNING: If unset, all write operations are unprotected!
# Generate one with: node -e "console.log(crypto.randomUUID())"
# API_KEY=

# Logging level (debug, info, warn, error)
# LOG_LEVEL=info

# CORS - comma-separated origins (leave empty to allow all in dev)
# PRODUCTION WARNING: Leaving this empty allows requests from any origin!
# CORS_ORIGINS=https://yourdomain.example.com

# Optional: threat intel API keys (free at https://auth.abuse.ch/)
# URLHAUS_AUTH_KEY=...
# THREATFOX_AUTH_KEY=...
